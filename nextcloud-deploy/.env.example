# Domain and SSL
# The fully qualified domain name for your Nextcloud instance
NEXTCLOUD_FQDN=nextcloud.example.com
# The email address for Let's Encrypt certificate expiry notifications
ACME_EMAIL=admin@example.com

# Database Settings
# The name of the PostgreSQL database
POSTGRES_DB=nextcloud
# The PostgreSQL user for Nextcloud
POSTGRES_USER=nextcloud
# The password for the PostgreSQL user
POSTGRES_PASSWORD=your_strong_db_password

# Nextcloud Initial Admin User (Optional)
# Uncomment these if you want Nextcloud to automatically install on first boot
# NEXTCLOUD_ADMIN_USER=admin
# NEXTCLOUD_ADMIN_PASSWORD=your_strong_admin_password
